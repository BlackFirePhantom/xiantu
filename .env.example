# 仙途环境变量配置
# 复制此文件为 .env 并修改

# 服务器密钥（不设置则自动生成并持久化到 data/.secret_key）
# XIANTU_SECRET_KEY=your-secret-key-here

# CORS 允许的来源（留空时仅允许同源连接）
# 留空时只允许同源 Socket.IO 连接；需要跨域时填写受信任域名（可用逗号分隔）
# XIANTU_CORS=https://your-domain.com

# 服务器端口（默认 5000）
# XIANTU_PORT=5000

# 服务器监听地址（默认 0.0.0.0）
# XIANTU_HOST=0.0.0.0
